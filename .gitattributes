# Normalize text files
* text=auto

# Flutter / Dart
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.lock text eol=lf
pubspec.lock text eol=lf

# CMake / Flutter Windows
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Web/design references
*.html text eol=lf
*.jsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf

# .NET
*.cs text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.sln text eol=crlf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.apk binary
*.aab binary
*.exe binary
*.dll binary
*.pdb binary
*.zip binary
*.7z binary
*.rar binary
